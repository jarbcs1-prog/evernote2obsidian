{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "server",
    "noEmit": false,
    "declaration": false,
    "lib": ["ES2022"]
  },
  "include": ["server/**/*.ts"]
}